<h1>Create new item</h1>
<%= form_with model: @item do |form| %>
  <div class="form-wrapper">
    <%= form.label :sku_prefix, "SKU-prefix" %>
    <%= form.text_field :sku_prefix %>
    <%= form.label :description %>
    <%= form.text_area :description %>
    <%= form.label :base_price %>
    <%= form.number_field :base_price, step: 0.01 %>
    <%= form.label :category %>
    <%= form.select :category, ["Parts", "Service", "Phone"], include_blank: true %>
    <%= form.label :active %>
    <%= form.select :active, ["false", "true"] %>
    <%= form.submit %>
  </div>
<% end %>
